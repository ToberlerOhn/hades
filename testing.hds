func fibonacci(n: int) => int {
    if (n <= 1) {
        => n
    }
    => fibonacci(n-1) + fibonacci(n-2)
}

func factorial(n: int) => int {
    result: int = 1;
    for (i: int = 1; i <= n; i++) {
        result *= i
    }
    => result
}

for (i: int = 0; i < 10; i++) {
    print(i, fibonacci(i), factorial(i))
}