{
	// "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Hades",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#types"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.hades",
				"match": "\\b(if|else|)\\b"
			}]
		},
		"types": {
			"patterns": [{
				"name": "storage.type.hades",
				"match": "\\b(int|float|bool|str)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.single.hades",
			"begin": "'",
			"end": "'",
			"patterns": [{
				"name": "constant.character.escape.hades",
				"match": "\\\\."
			}]
		},
		"numbers": {
			"patterns": [{
				"match": "\\b\\d+(\\.\\d+)?\\b",
				"name": "constant.numeric.hades"
			}]
		}
	},
	"scopeName": "source.hades"
}