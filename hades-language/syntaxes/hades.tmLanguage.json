{
  "scopeName": "source.hades",
  "name": "Hades",
  "patterns": [
    { "include": "#comments"},
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" }

  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hades",
          "match": "//.+$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hades",
          "match": "\\b(if|else|do|while|for|func|return)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.hades",
          "match": "\\b(int|float|bool|str|nothing)\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hades",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.hades",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.hades",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.hades",
          "match": "\\+|-\\*|/|%|&|\\|^|!|=|>|<"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.hades",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\(.*)"
        }
      ]
    }
  }
}